{
  "DatabaseProvider": "PostgreSQL",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=taskmanagementdb;Username=taskadmin;Password=<YOUR_DB_PASSWORD_HERE>",
    "OracleConnection": "Data Source=localhost:1521/XEPDB1;User Id=myuser;Password=<YOUR_ORACLE_PASSWORD_HERE>"
  },
  "Jwt": {
    "Secret": "<YOUR_JWT_SECRET_KEY_HERE>",
    "Issuer": "TaskManagement.API",
    "Audience": "TaskManagement.Client",
    "ExpiryMinutes": 1440
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
